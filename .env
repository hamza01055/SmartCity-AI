POSTGRES_DB=smartcity

# --- Backend ---
PORT=3333
HOST=0.0.0.0
DB_HOST=postgres
DB_PORT=5432
DB_USER=smartcity
DB_PASSWORD=smartcity
DB_DATABASE=smartcity
REDIS_HOST=redis
