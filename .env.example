# --- Postgres ---
POSTGRES_USER=smartcity
POSTGRES_PASSWORD=smartcity
POSTGRES_DB=smartcity

# --- Backend (AdonisJS) ---
APP_KEY=ChangeMeToA32CharRandomStringNow!
NODE_ENV=development
PORT=3333
HOST=0.0.0.0
DB_HOST=postgres
DB_PORT=5432
DB_USER=smartcity
DB_PASSWORD=smartcity
DB_DATABASE=smartcity
REDIS_HOST=redis
REDIS_PORT=6379
ML_SERVICE_URL=http://ml_service:8000

# --- Storage (local for dev, swap to S3/Cloudinary in prod) ---
STORAGE_DRIVER=local
UPLOADS_DIR=/app/uploads

# --- Frontend ---
VITE_API_URL=http://localhost:3333
VITE_SOCKET_URL=http://localhost:3333

# --- ML Service ---
USE_REAL_MODEL=true
MODEL_PATH=/app/weights/best.pt
# If using Roboflow hosted inference (Rapid), set both of these:
ROBOFLOW_API_KEY=
ROBOFLOW_MODEL=
# Format: workspace-slug/project-slug/version-number  (e.g. hamzas-workspace-imchr/pothole-rapid/1)
